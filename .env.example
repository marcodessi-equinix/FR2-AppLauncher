# ── Required ─────────────────────────────────────────────
# A random secret used to sign JWT tokens (min 32 chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Admin login password.
ADMIN_PASSWORD=

# ── Optional (uncomment to override defaults) ────────────
# Host port the app listens on.
# APP_PORT=9020

# Cookie security: auto | true | false
# "auto" detects HTTPS via X-Forwarded-Proto header.
# COOKIE_SECURE=auto
