# ── Required ─────────────────────────────────────────────
# A random secret used to sign JWT tokens (min 32 chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Admin login password.
ADMIN_PASSWORD=

# ── Optional (uncomment to override defaults) ────────────
# Host port the app listens on.
# APP_PORT=9020

# Cookie security: auto | true | false
# "auto" detects HTTPS via X-Forwarded-Proto header.
# COOKIE_SECURE=auto

# ── Reverse Proxy (NPM, Traefik, etc.) ───────────────────
# Name of your reverse proxy's Docker network.
# Find it with: docker network ls
NPM_NETWORK=nginx-proxy-manager_default

# Cookie security: set to "true" when your proxy terminates SSL.
# COOKIE_SECURE=true

# Optional: your public URL for stricter CORS origin checking.
# FRONTEND_URL=https://applauncher.example.com

# Optional build metadata overrides for CI/CD.
# If left empty, the frontend build derives them automatically when possible.
# APP_VERSION=2.0.0
# APP_GIT_SHA=abc1234
# APP_BUILD_DATE=2026-04-08
# APP_BUILD_TIME=14:30:00
# APP_BUILD_NUMBER=123
