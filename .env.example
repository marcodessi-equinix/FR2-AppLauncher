# ── Required ─────────────────────────────────────────────
# A random secret used to sign JWT tokens (min 32 chars).
JWT_SECRET=replace-with-64-hex-chars-or-other-long-random-secret

# Admin login password (plaintext or bcrypt hash).
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# ── Optional ─────────────────────────────────────────────
# Port the app is reachable on (host side).
APP_PORT=9020

# Cookie security mode: auto | true | false
# "auto" detects HTTPS via X-Forwarded-Proto header.
COOKIE_SECURE=auto

# Extra allowed CORS origins (comma-separated, usually empty).
FRONTEND_URL=

# SQLite database path inside the container.
DATABASE_PATH=/app/data/applauncher.db
