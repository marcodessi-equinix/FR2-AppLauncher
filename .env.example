# AppLauncher direct compose example
# Copy to .env when using: docker compose up -d --build

# -- Required ------------------------------------------------------
# A random secret used to sign JWT tokens (min 32 chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Admin login password.
ADMIN_PASSWORD=

# -- Direct host-port deployment ----------------------------------
# Host port published by docker-compose.yml.
APP_PORT=9020

# Cookie security: auto | true | false
# "auto" trusts X-Forwarded-Proto when present and otherwise follows the request.
COOKIE_SECURE=auto

# Optional public URL when a host-level reverse proxy forwards to APP_PORT.
# FRONTEND_URL=http://localhost:9020

# Optional: override runtime storage paths.
# Relative paths are resolved from the container workdir.
# DATABASE_PATH=/app/data/applauncher.db
# UPLOAD_PATH=/app/uploads/icons

# -- Optional build metadata overrides -----------------------------
# Normal installs do not need these. The image derives version,
# git sha and build timestamp automatically from package.json,
# git metadata and build time.
# BUILD_VERSION=2.1.0
# BUILD_DATE=2026-04-10T12:34:56.000Z
# GIT_SHA=abc1234

# Optional CI metadata overrides
# BUILD_TIME=14:30:00
# BUILD_NUMBER=123
