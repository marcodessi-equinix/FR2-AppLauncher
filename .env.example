PORT=3000
FRONTEND_PORT=9020
DATABASE_PATH=/app/data/applauncher.db
PROXY_NETWORK=nginx-proxy-manager_default
VITE_BUILD_NUMBER=001
FRONTEND_URL=
COOKIE_SECURE=false
ALLOW_INSECURE_DEFAULTS=false

# Required for production and Portainer stacks
JWT_SECRET=replace-with-64-hex-chars-or-other-long-random-secret
# Plaintext or bcrypt hash
ADMIN_PASSWORD=replace-with-a-strong-admin-password
